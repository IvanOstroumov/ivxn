# Password to access /admin. Set a strong value in Vercel's env vars for production.
ADMIN_PASSWORD=

# Vercel Blob token (Vercel Storage tab) — enables real file uploads and persisted
# content edits in production. Without it, the admin panel falls back to writing
# local JSON/files, which only works in local dev (Vercel's filesystem is read-only).
BLOB_READ_WRITE_TOKEN=
