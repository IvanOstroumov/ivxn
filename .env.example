# Password to access /admin. Set a strong value in Vercel's env vars for production.
ADMIN_PASSWORD=

# Vercel Blob token (Vercel Storage tab) — enables real file uploads and persisted
# content edits in production. Without it, the admin panel falls back to writing
# local JSON/files, which only works in local dev (Vercel's filesystem is read-only).
BLOB_READ_WRITE_TOKEN=

# Plausible analytics domain (e.g. ivxn.dev) — leave empty to disable analytics entirely.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Resend API key (resend.com, free tier) — powers the real contact form.
# Without it, the form shows a clear "not configured yet" error instead of
# silently failing. Sends from the shared onboarding@resend.dev sandbox
# address until ivxn.dev is verified as a sending domain with Resend.
RESEND_API_KEY=
